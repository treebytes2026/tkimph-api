APP_NAME=TKIMPH
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.tkimph.com

FRONTEND_URL=https://tkimph.com
CORS_ALLOWED_ORIGINS=https://tkimph.com,https://www.tkimph.com
TRUSTED_HOSTS=api.tkimph.com,ws.tkimph.com,tkimph.com,www.tkimph.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=tkimph
DB_USERNAME=tkimph
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.tkimph.com

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
CACHE_STORE=redis
RATE_LIMIT_USE_REDIS=true

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@tkimph.com"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=tkimph-production
REVERB_APP_KEY=CHANGE_THIS_REVERB_APP_KEY
REVERB_APP_SECRET=CHANGE_THIS_REVERB_APP_SECRET
REVERB_HOST=ws.tkimph.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"
